# HTTP server
PORT=3000

# Local persistence (SQLite)
DATA_DIR=./data
DB_FILE=./data/survey.db
UPLOADS_DIR=./data/uploads
# Legacy JSON store path (no longer used, kept for reference)
# STORE_FILE=./data/store.json

# Reserved for future admin authentication hardening
ADMIN_TOKEN=

# Google Sheets mirror (optional)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
GOOGLE_SHEETS_SUBMISSIONS_RANGE=Submissions!A:Z
GOOGLE_SHEETS_ASSIGNMENTS_RANGE=Assignments!A:Z

# The built-in submission row now mirrors the shared survey sheet structure:
# 기본정보 + 제품별 판매가(이온킥/포카리스웨트/파워에이드/게토레이/썬키스트)
